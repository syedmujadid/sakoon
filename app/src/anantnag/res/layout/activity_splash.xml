<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:background="@color/colorWhite"
    android:layout_height="match_parent"
    >
    <TextView
        android:id="@+id/sub_text"
        style="@style/TextViewStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@color/colorGrayBorder"
        android:fontFamily="@font/poppins_medium"
        android:gravity="center_horizontal"
        android:padding="@dimen/d_10dp"
        android:text="@string/fotter_tag"
        android:textColor="@color/colorBlack"
        android:textSize="12sp" />
    <ImageView
        android:id="@+id/img3"
        android:layout_centerVertical="true"
        app:srcCompat="@drawable/powered_by"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_margin="@dimen/d_20dp"
        android:visibility="gone"
        android:background="@drawable/rectangle_background_grey"
        android:padding="@dimen/d_10dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_margin="@dimen/d_20dp"
        android:layout_centerInParent="true"
        android:layout_height="wrap_content">
     <ImageView
         app:srcCompat="@drawable/sakoonlogo"
         android:layout_centerHorizontal="true"
         android:layout_width="300dp"
         android:layout_height="wrap_content" />
    </RelativeLayout>
</RelativeLayout>