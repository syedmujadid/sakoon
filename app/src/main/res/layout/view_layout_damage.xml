<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_marginTop="@dimen/d_10dp"
    android:elevation="5dp"
    android:orientation="vertical">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/rectangle_background_grey_damage">



        <ImageView
            android:id="@+id/delete"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:layout_marginRight="@dimen/d_10dp"
            app:srcCompat="@drawable/ic_delete_white" />

        <ImageView
            android:id="@+id/edit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toLeftOf="@id/delete"
            android:layout_centerVertical="true"
            android:layout_marginRight="@dimen/d_10dp"
            app:srcCompat="@drawable/ic_edit" />
        <TextView
            android:id="@+id/title"
            style="@style/TextViewStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentLeft="true"
            android:layout_toLeftOf="@id/edit"
            android:layout_marginRight="10dp"
            android:fontFamily="@font/poppins_medium"
            android:padding="@dimen/d_10dp"
            android:text="Property Type"
            android:textColor="@color/colorWhite"
            android:textSize="@dimen/text_size_small" />
    </RelativeLayout>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/rectangle_background_curve_damage"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/d_10dp">

            <TextView
                android:id="@+id/propertyType"
                style="@style/TextViewStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_medium"
                android:text="Type"
                android:textSize="@dimen/text_size_small" />


            <TextView
                android:id="@+id/desLabel"
                style="@style/TextViewStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/d_5dp"
                android:fontFamily="@font/poppins_medium"
                android:text="Description:"
                android:textSize="@dimen/text_size_small" />

            <TextView
                android:id="@+id/damageDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:enabled="false"
                android:fontFamily="@font/poppins_medium"
                android:gravity="top"
                android:imeOptions="actionDone"
                android:inputType="textMultiLine"
                android:maxLines="10"
                android:textColor="@color/colorGray"
                android:textSize="@dimen/text_size_small"
                tools:hint="Things Got Damaged" />

            <TextView
                android:id="@+id/quantity"
                style="@style/TextViewStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/d_5dp"
                android:fontFamily="@font/poppins_medium"
                android:text="Quantity"
                android:textSize="@dimen/text_size_small" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/reliefLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            >

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/colorGrayBorder" />

            <TextView
                android:id="@+id/baseAmnt"
                style="@style/TextViewStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/d_10dp"
                android:layout_marginTop="@dimen/d_5dp"
                android:layout_marginRight="@dimen/d_10dp"
                android:fontFamily="@font/poppins_semibold"
                android:text="Quantity"
                android:textColor="@color/colorBlack"
                android:textSize="@dimen/text_size_small" />

            <TextView
                android:id="@+id/totalAmnt"
                style="@style/TextViewStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/d_10dp"
                android:layout_marginTop="@dimen/d_5dp"
                android:layout_marginRight="@dimen/d_10dp"
                android:layout_marginBottom="@dimen/d_5dp"
                android:fontFamily="@font/poppins_semibold"
                android:text="Quantity"
                android:textColor="@color/colorBlack"
                android:textSize="@dimen/text_size_small" />
        </LinearLayout>

    </LinearLayout>


</LinearLayout>