<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rl_main"
    android:layout_width="match_parent"
    android:orientation="horizontal"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/d_4dp"
    android:layout_marginBottom="@dimen/d_4dp"
    android:background="@drawable/rectangle_background_curve"
    android:padding="@dimen/d_5dp"
    app:cardCornerRadius="@dimen/d_4dp"
    app:cardElevation="@dimen/d_2dp">

  <LinearLayout
      android:layout_width="0dp"
      android:layout_weight="0.6"
      android:orientation="vertical"
      android:padding="@dimen/d_5dp"
      android:gravity="center_vertical"
      android:layout_height="wrap_content">
      <TextView
          android:fontFamily="@font/poppins_medium"
          android:textSize="@dimen/text_size_normal"
          android:id="@+id/fileName"
          android:layout_width="match_parent"
          android:textColor="@color/colorBlack"
          android:layout_height="wrap_content" />
      <TextView
          android:layout_marginTop="@dimen/d_5dp"
          android:fontFamily="@font/poppins_medium"
          android:textSize="@dimen/text_size_small"
          android:id="@+id/optionalStatus"
          android:layout_width="match_parent"
          android:textColor="@color/orange_dark"
          android:layout_height="wrap_content" />
  </LinearLayout>
    <RelativeLayout
        android:layout_width="0dp"
        android:layout_weight="0.4"
        android:layout_gravity="center_vertical"
        android:layout_height="wrap_content">
        <TextView
            android:text="Upload"
            android:paddingLeft="@dimen/d_20dp"
            android:paddingRight="@dimen/d_20dp"
            android:layout_alignParentRight="true"
            android:paddingTop="@dimen/d_5dp"
            android:paddingBottom="@dimen/d_5dp"
            android:textColor="@color/colorWhite"
            android:background="@drawable/rectangle_background_grey"
            android:fontFamily="@font/poppins_medium"
            android:id="@+id/upload"
            android:textSize="@dimen/d_10dp"
            android:visibility="visible"
            android:gravity="center_horizontal"
            android:layout_width="100dp"
            android:layout_height="wrap_content" />
        <TextView
            android:text="N/A"
            android:paddingLeft="@dimen/d_20dp"
            android:paddingRight="@dimen/d_20dp"
            android:layout_alignParentRight="true"
            android:paddingTop="@dimen/d_5dp"
            android:paddingBottom="@dimen/d_5dp"
            android:textColor="@color/colorBlack"
            android:fontFamily="@font/poppins_semibold"
            android:id="@+id/na"
            android:visibility="gone"
            android:textSize="@dimen/d_16dp"
            android:gravity="center_horizontal"
            android:layout_width="100dp"
            android:layout_height="wrap_content" />
        <TextView
            android:text="View"
            android:paddingLeft="@dimen/d_20dp"
            android:paddingRight="@dimen/d_20dp"
            android:layout_alignParentRight="true"
            android:paddingTop="@dimen/d_5dp"
            android:paddingBottom="@dimen/d_5dp"
            android:textColor="@color/colorWhite"
            android:background="@drawable/rectangle_background_green"
            android:fontFamily="@font/poppins_medium"
            android:id="@+id/view"
            android:textSize="@dimen/d_10dp"
            android:visibility="gone"
            android:gravity="center_horizontal"
            android:layout_width="100dp"
            android:layout_height="wrap_content" />
        <TextView
            android:text="Edit"
            android:paddingLeft="@dimen/d_20dp"
            android:paddingRight="@dimen/d_20dp"
            android:layout_alignParentRight="true"
            android:paddingTop="@dimen/d_5dp"
            android:paddingBottom="@dimen/d_5dp"
            android:textColor="@color/colorWhite"
            android:background="@drawable/rectangle_background_blue"
            android:fontFamily="@font/poppins_medium"
            android:id="@+id/edit"
            android:layout_marginTop="@dimen/d_5dp"
            android:gravity="center_horizontal"
            android:visibility="gone"
            android:layout_width="100dp"
            android:layout_below="@id/view"
            android:textSize="@dimen/d_10dp"
            android:layout_height="wrap_content" />
    </RelativeLayout>
</LinearLayout>