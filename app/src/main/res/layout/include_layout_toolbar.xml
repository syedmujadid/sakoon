<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rl_toolbar"
    android:layout_width="match_parent"
    android:layout_height="?android:attr/actionBarSize"
    android:background="@color/colorBlack"
    android:elevation="@dimen/d_2dp">

    <LinearLayout
        android:id="@+id/l1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentLeft="true"
        android:layout_centerVertical="true"
        android:layout_marginRight="@dimen/d_10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/menu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingLeft="@dimen/d_5dp"
            android:paddingRight="@dimen/d_5dp"
            app:srcCompat="@drawable/ic_back" />


        <TextView
            android:id="@+id/tab_name"
            style="@style/TextViewStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins_semibold"
            android:singleLine="true"
            android:text="Settings"
            android:textColor="@color/colorWhite"
            android:textSize="@dimen/d_16dp" />


    </LinearLayout>

    <RelativeLayout
        android:id="@+id/l2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentRight="true"
        android:visibility="gone"
        android:layout_centerVertical="true"
        android:layout_marginRight="@dimen/d_10dp"
        >

        <ImageView
            android:id="@+id/im1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:srcCompat="@drawable/ic_add_circle_wite" />

        <ImageView
            android:id="@+id/im2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:srcCompat="@drawable/ic_list" />
    </RelativeLayout>

    <RadioGroup
        android:id="@+id/lanGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_toLeftOf="@id/l2"
        android:visibility="gone"
        android:layout_marginRight="@dimen/d_10dp"
        android:orientation="horizontal">

        <RadioButton
            android:id="@+id/english"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/radio_selector_2"
            android:button="@android:color/transparent"
            android:checked="true"
            android:fontFamily="@font/poppins_regular"
            android:gravity="center"
            android:paddingLeft="@dimen/d_10dp"
            android:paddingTop="@dimen/d_5dp"
            android:paddingRight="@dimen/d_10dp"
            android:paddingBottom="@dimen/d_5dp"
            android:text="English"
            android:textColor="@color/radio_text_selector_2"
            android:textSize="@dimen/text_size_small" />

        <RadioButton
            android:id="@+id/hindi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/radio_selector_2_v2"
            android:button="@android:color/transparent"
            android:fontFamily="@font/poppins_regular"
            android:gravity="center"
            android:paddingLeft="@dimen/d_10dp"
            android:paddingTop="@dimen/d_5dp"
            android:paddingRight="@dimen/d_10dp"
            android:paddingBottom="@dimen/d_5dp"
            android:text="हिंदीं"

            android:textColor="@color/radio_text_selector_2"
            android:textSize="@dimen/text_size_small" />

    </RadioGroup>
</RelativeLayout>