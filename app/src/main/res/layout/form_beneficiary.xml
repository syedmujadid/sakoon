<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rl_main"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="@dimen/d_5dp"
    android:background="@drawable/rectangle_background_curve"
    android:layout_marginTop="@dimen/d_10dp"
    android:layout_marginBottom="@dimen/d_10dp"
    android:orientation="vertical">

  <LinearLayout
        android:id="@+id/mainFormlayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            style="@style/TextViewStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginTop="@dimen/d_10dp"
            android:fontFamily="@font/poppins_medium"
            android:text="Name of Person *"
            android:textSize="@dimen/text_size_small" />


        <EditText
            android:id="@+id/personName"
            style="@style/EditTextStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/d_5dp"
            android:background="@drawable/selector_edittext_create_account"
            android:fontFamily="@font/poppins_medium"
            android:textSize="@dimen/text_size_small"
            android:inputType="textEmailAddress|textCapCharacters"
            android:imeOptions="actionNext"
            tools:hint="Enter Person Name" />

        <TextView
            style="@style/TextViewStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/d_10dp"
            android:fontFamily="@font/poppins_medium"
            android:text="Gender"
            android:textSize="@dimen/text_size_small" />


        <RadioGroup
            android:id="@+id/genderRadioGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/d_5dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/maleRg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/radio_selector"
                android:button="@android:color/transparent"
                android:checked="true"
                android:drawablePadding="@dimen/d_10dp"
                android:fontFamily="@font/poppins_regular"
                android:gravity="center"
                android:paddingLeft="@dimen/d_20dp"
                android:paddingTop="@dimen/d_5dp"
                android:paddingRight="@dimen/d_20dp"
                android:paddingBottom="@dimen/d_5dp"
                android:text="Male"
                android:textColor="@color/radio_text_selector"
                android:textSize="@dimen/text_size_small" />

            <RadioButton
                android:id="@+id/femaleRg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/radio_selector"
                android:button="@android:color/transparent"
                android:drawablePadding="@dimen/d_10dp"
                android:fontFamily="@font/poppins_regular"
                android:gravity="center"
                android:paddingLeft="@dimen/d_20dp"
                android:paddingTop="@dimen/d_5dp"
                android:paddingRight="@dimen/d_20dp"
                android:paddingBottom="@dimen/d_5dp"
                android:text="Female"
                android:textColor="@color/radio_text_selector"
                android:textSize="@dimen/text_size_small" />

        </RadioGroup>

        <TextView
            style="@style/TextViewStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/d_10dp"
            android:fontFamily="@font/poppins_medium"
            android:text="Aadhaar Number *"
            android:textSize="@dimen/text_size_small" />

        <EditText
            android:id="@+id/adharNumber"
            style="@style/EditTextStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/d_5dp"
            android:background="@drawable/selector_edittext_create_account"
            android:fontFamily="@font/poppins_medium"
            android:imeOptions="actionNext"
            android:inputType="number"
            android:maxLength="12"
            android:textSize="@dimen/text_size_small"
            tools:hint="Enter Adhar Number" />

        <TextView
            style="@style/TextViewStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/d_10dp"
            android:fontFamily="@font/poppins_medium"
            android:text="Address *"
            android:textSize="@dimen/text_size_small" />

        <EditText
            android:id="@+id/adharAddress"
            style="@style/EditTextStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/d_5dp"
            android:background="@drawable/selector_edittext_create_account"
            android:fontFamily="@font/poppins_medium"
            android:gravity="top"
            android:imeOptions="actionNext"
            android:inputType="textPostalAddress|textMultiLine|textCapWords"
            android:lines="3"
            android:textSize="@dimen/text_size_small"
            tools:hint="Enter Address" />

        <TextView
            style="@style/TextViewStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/d_10dp"
            android:fontFamily="@font/poppins_medium"
            android:text="Contact Number"
            android:textSize="@dimen/text_size_small" />

        <EditText
            android:id="@+id/contactNumber"
            style="@style/EditTextStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/d_5dp"
            android:background="@drawable/selector_edittext_create_account"
            android:fontFamily="@font/poppins_medium"
            android:imeOptions="actionNext"
            android:maxLength="10"
            android:inputType="number"
            android:textSize="@dimen/text_size_small"
            tools:hint="Enter Contact Number" />

        <TextView
            style="@style/TextViewStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/d_10dp"
            android:fontFamily="@font/poppins_medium"
            android:text="Pin Code *"
            android:textSize="@dimen/text_size_small" />

        <EditText
            android:id="@+id/pinCode"
            style="@style/EditTextStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/d_5dp"
            android:background="@drawable/selector_edittext_create_account"
            android:fontFamily="@font/poppins_medium"
            android:imeOptions="actionNext"
            android:inputType="number"
            android:maxLength="6"
            android:textSize="@dimen/text_size_small"
            tools:hint="Enter Pin Code" />

        <TextView
            style="@style/TextViewStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/d_10dp"
            android:fontFamily="@font/poppins_medium"
            android:text="Select amount of share (in %age) *"
            android:textSize="@dimen/text_size_small" />

       <!-- <EditText
            android:id="@+id/percentageShare"
            style="@style/EditTextStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/d_5dp"
            android:background="@drawable/selector_edittext_create_account"
            android:fontFamily="@font/poppins_medium"
            android:imeOptions="actionNext"
            android:inputType="numberDecimal"
            android:textSize="@dimen/text_size_small"
            tools:hint="Enter Percentage Share" />-->
        <Spinner
            android:id="@+id/percentageShare"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/d_5dp"
            android:elevation="2dp"
            android:padding="@dimen/d_5dp"
            android:entries="@array/shareAmntArray"
            ></Spinner>

        <TextView
            style="@style/TextViewStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/d_10dp"
            android:fontFamily="@font/poppins_semibold"
            android:text="Enter bank details"
            android:textColor="@color/colorBlack"
            android:textSize="@dimen/text_size_normal" />

        <TextView
            style="@style/TextViewStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/d_10dp"
            android:fontFamily="@font/poppins_medium"
            android:text="Account Holder Name *"

            android:textSize="@dimen/text_size_small" />

        <EditText
            android:id="@+id/accountHolderName"
            style="@style/EditTextStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/d_5dp"
            android:background="@drawable/selector_edittext_create_account"
            android:fontFamily="@font/poppins_medium"
            android:imeOptions="actionNext"
            android:inputType="textEmailAddress|textCapCharacters"
            android:textSize="@dimen/text_size_small"
            tools:hint="Enter account holder name" />

        <TextView
            style="@style/TextViewStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/d_10dp"
            android:fontFamily="@font/poppins_medium"
            android:text="Relation with Claimant  *"
            android:textSize="@dimen/text_size_small" />



            <Spinner
                android:id="@+id/applicantRelation"
                android:layout_width="match_parent"
                android:padding="@dimen/d_5dp"
                android:entries="@array/relationArray"
                android:layout_marginTop="@dimen/d_5dp"
                android:elevation="2dp"
                android:layout_height="wrap_content"></Spinner>


        <TextView
            style="@style/TextViewStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/d_10dp"
            android:fontFamily="@font/poppins_medium"
            android:text="Account Number  *"
            android:textSize="@dimen/text_size_small" />

        <EditText
            android:id="@+id/accountNumber"
            style="@style/EditTextStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/d_5dp"
            android:background="@drawable/selector_edittext_create_account"
            android:fontFamily="@font/poppins_medium"
            android:imeOptions="actionNext"
            android:inputType="number"
            android:textSize="@dimen/text_size_small"
            tools:hint="Enter account number" />

        <TextView
            style="@style/TextViewStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/d_10dp"
            android:fontFamily="@font/poppins_medium"
            android:text="Bank Name  *"
            android:textSize="@dimen/text_size_small" />

        <EditText
            android:id="@+id/bankame"
            style="@style/EditTextStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/d_5dp"
            android:background="@drawable/selector_edittext_create_account"
            android:fontFamily="@font/poppins_medium"
            android:imeOptions="actionNext"
            android:inputType="textEmailAddress|textCapCharacters"
            android:textSize="@dimen/text_size_small"
            tools:hint="Enter Bank Name" />

        <TextView
            style="@style/TextViewStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/d_10dp"
            android:fontFamily="@font/poppins_medium"
            android:text="Branch Name"
            android:textSize="@dimen/text_size_small" />

        <EditText
            android:id="@+id/branchName"
            style="@style/EditTextStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/d_5dp"
            android:background="@drawable/selector_edittext_create_account"
            android:fontFamily="@font/poppins_medium"
            android:imeOptions="actionNext"
            android:inputType="textEmailAddress|textCapCharacters"
            android:textSize="@dimen/text_size_small"
            tools:hint="Enter Branch Name" />

        <TextView
            style="@style/TextViewStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/d_10dp"
            android:fontFamily="@font/poppins_medium"
            android:text="IFSC Code *"
            android:textSize="@dimen/text_size_small" />

        <EditText
            android:id="@+id/ifscCode"
            style="@style/EditTextStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/d_5dp"
            android:background="@drawable/selector_edittext_create_account"
            android:fontFamily="@font/poppins_medium"
            android:imeOptions="actionDone"
            android:inputType="textCapCharacters"
            android:textSize="@dimen/text_size_small"
            tools:hint="Enter IFSC Code" />


    </LinearLayout>

</LinearLayout>