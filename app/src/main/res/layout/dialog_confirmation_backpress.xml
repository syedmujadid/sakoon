<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:layout_margin="@dimen/d_20dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:background="@drawable/rectangle_background_curve"
        android:padding="@dimen/d_10dp"
        android:layout_marginTop="@dimen/d_10dp"
        android:layout_marginRight="@dimen/d_10dp"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tv_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_margin="@dimen/d_10dp"
            android:gravity="center_horizontal"
            android:text=""
            android:textColor="@color/colorBlack"
            android:textSize="@dimen/text_size_normal" />


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/tv_message"
            android:layout_marginTop="@dimen/d_10dp"
            android:layout_marginLeft="@dimen/d_10dp"
            android:layout_marginRight="@dimen/d_10dp">

            <Button
                android:id="@+id/tv_negative"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/rectangle_background_grey"
                android:fontFamily="@font/poppins_medium"
                android:text="NO"
                android:textColor="@color/colorWhite"
                android:textSize="@dimen/text_size_normal" />


            <Button
                android:id="@+id/tv_positive"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/d_10dp"
                android:layout_weight="1"
                android:background="@drawable/rectangle_background_green"
                android:fontFamily="@font/poppins_medium"
                android:text="YES"
                android:textColor="@color/colorWhite" />


        </LinearLayout>

    </RelativeLayout>
    <ImageView
        android:id="@+id/tv_neutral"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentRight="true"
        android:background="@drawable/circle_shape_orange"
        android:padding="@dimen/d_2dp"
        app:srcCompat="@drawable/ic_close_white" />
</RelativeLayout>